{
  "info": {
    "name": "Digital Cafeteria Auth Service",
    "description": "Collection for testing the Authentication Microservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3001/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["health"]
        },
        "description": "Check if MongoDB is connected. Returns 200 if healthy, 503 if unhealthy."
      },
      "response": []
    },
    {
      "name": "Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3001/metrics",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["metrics"]
        },
        "description": "Get service metrics: totalRequests, successfulLogins, failedLogins, averageResponseTime"
      },
      "response": []
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"John Doe\",\n  \"id\": \"IUT-001\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3001/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["register"]
        },
        "description": "Register a new user with name, ID, and password"
      },
      "response": []
    },
    {
      "name": "Login - Successful",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"IUT-001\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3001/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["login"]
        },
        "description": "Login with student ID and password. Rate limited to 3 attempts per minute per student ID."
      },
      "response": []
    },
    {
      "name": "Login - Failed (Wrong Password)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"IUT-001\",\n  \"password\": \"wrongpassword\"\n}"
        },
        "url": {
          "raw": "http://localhost:3001/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["login"]
        },
        "description": "Login with wrong password - will increment failedLogins counter"
      },
      "response": []
    },
    {
      "name": "Login - Rate Limited (4th attempt)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"IUT-001\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:3001/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["login"]
        },
        "description": "Make this request 4 times rapidly to trigger rate limiting (429 status code)"
      },
      "response": []
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": {
          "raw": "http://localhost:3001/logout",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["logout"]
        },
        "description": "Logout - clears token cookie and blacklists the token"
      },
      "response": []
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer YOUR_TOKEN_HERE",
            "description": "Replace with actual JWT token from login response"
          }
        ],
        "url": {
          "raw": "http://localhost:3001/profile",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3001",
          "path": ["profile"]
        },
        "description": "Get user profile - requires valid JWT token in Authorization header"
      },
      "response": []
    }
  ]
}
